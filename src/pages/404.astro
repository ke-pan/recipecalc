---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/landing.css';

const title = 'Page Not Found — RecipePricer';
const description = "The page you were looking for doesn't exist.";
---

<BaseLayout title={title} description={description} noindex>
  <section class="not-found">
    <p class="not-found__label">404</p>
    <h1 class="not-found__heading">This page doesn't exist</h1>
    <p class="not-found__desc">Maybe the recipe was too good to share. Or maybe it's just a typo.</p>
    <div class="not-found__links">
      <a href="/" class="btn">Back to home</a>
      <a href="/calculator" class="not-found__link">or try the calculator</a>
    </div>
  </section>

  <footer class="landing-footer">
    <p>&copy; 2026 RecipePricer. Know your true cost. Price with confidence.</p>
  </footer>
</BaseLayout>

<style>
  .not-found {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    min-height: 70vh;
    padding: var(--space-xl) var(--space-lg);
  }

  .not-found__label {
    font-family: var(--font-display);
    font-size: 6rem;
    font-weight: 700;
    color: var(--border);
    line-height: 1;
    margin-bottom: var(--space-sm);
  }

  .not-found__heading {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    margin-bottom: var(--space-md);
  }

  .not-found__desc {
    color: var(--text-muted);
    max-width: 380px;
    margin-bottom: var(--space-xl);
  }

  .not-found__links {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
  }

  .not-found__link {
    color: var(--text-muted);
    text-decoration: none;
    font-size: var(--text-sm);
  }

  .not-found__link:hover {
    color: var(--accent);
  }
</style>
