---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroCarousel from '../components/hero/HeroCarousel';
import '../components/hero/hero.css';

const title = 'RecipeCalc — Recipe Cost Calculator for Home Bakers';
const description =
  'Know your true recipe cost and price with confidence. Free recipe cost calculator for home bakers, cottage food sellers, and small bakeries.';
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://recipecalc.app/" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
  </Fragment>

  <main class="container">
    <HeroCarousel client:load />
  </main>
</BaseLayout>
