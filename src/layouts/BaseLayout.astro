---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'RecipeCalc — Pricing Therapist for Home Bakers',
  description = 'Know your true recipe cost. Price with confidence.',
} = Astro.props;

const umamiWebsiteId = import.meta.env.PUBLIC_UMAMI_WEBSITE_ID;
const umamiSrc = import.meta.env.PUBLIC_UMAMI_SRC;
const enableUmami = import.meta.env.PROD && !!umamiWebsiteId && !!umamiSrc;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Google Fonts: Fraunces (heading), DM Sans (body), Geist Mono (data) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..900&family=DM+Sans:wght@400..600&family=Geist+Mono:wght@400..600&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
    <slot name="head" />
    {enableUmami && (
      <script defer src={umamiSrc} data-website-id={umamiWebsiteId}></script>
    )}

    <!-- Lemon.js: LemonSqueezy checkout overlay (deferred, loads after page) -->
    <script src="https://app.lemonsqueezy.com/js/lemon.js" defer></script>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
