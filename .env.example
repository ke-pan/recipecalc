# LemonSqueezy — store/product IDs (public, embedded in client bundle)
# Get these from your LemonSqueezy dashboard → Store Settings / Product page
PUBLIC_LS_STORE_ID=
PUBLIC_LS_PRODUCT_ID=

# Session signing secret (server-side only, never exposed to client)
# Generate: node -e "console.log(crypto.randomUUID()+crypto.randomUUID())"
# For production: wrangler secret put SESSION_SECRET
SESSION_SECRET=

# Umami Analytics (leave empty to disable tracking)
PUBLIC_UMAMI_WEBSITE_ID=
PUBLIC_UMAMI_SRC=

# LemonSqueezy Checkout Overlay URL (Lemon.js)
# Format: https://recipecalc.lemonsqueezy.com/buy/xxx
PUBLIC_LS_CHECKOUT_URL=
